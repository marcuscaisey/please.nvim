{
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        ".",
        "-p",
        "*_test.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    "files.watcherExclude": {
        "plz-out": true
    },
    "search.exclude": {
        "plz-out": true
    },
    "files.exclude": {
        "plz-out": true
    },
    "gopls": {
        "build.directoryFilters": [
            "-**/node_modules",
            "-plz-out"
        ]
    }
}
