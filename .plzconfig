[Please]
version = 17.30.0

[BuildConfig]
nvim-tool = //third_party/neovim:toolchain_stable|nvim
lua-tool = //third_party/lua:toolchain|lua
luarocks-tool = //third_party/lua:luarocks|luarocks
puku-version = "1.17.1"

[Plugin "go"]
target = //plugins:go
gotool = //third_party/go:toolchain|go
delvetool = ///third_party/go/github.com_go-delve_delve//cmd/dlv
modfile = //:gomod
importpath = github.com/marcuscaisey/please.nvim

[Plugin "python"]
target = //plugins:python
disablevendorflags = true
moduledir = third_party/python

[Plugin "shell"]
target = //plugins:shell

[Plugin "cc"]
target = //plugins:cc

[Sandbox]
build = true
test = true

[Remote]
url =
instance =
numexecutors = 0

[Alias "puku"]
Cmd = run //third_party/binary:puku --
PositionalLabels = true
Desc = A tool to update BUILD files in Go packages

[Alias "minimal_nvim"]
cmd = run //tools:minimal_nvim --
desc = Launches stable version of Neovim with a minimal config
