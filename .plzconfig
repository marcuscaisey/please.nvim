[Please]
version = 17.29.1

[BuildConfig]
nvim-tool = //third_party/neovim:toolchain_0_12_0|nvim
lua-tool = //third_party/lua:toolchain|lua
luarocks-tool = //third_party/lua:luarocks|luarocks

[Plugin "go"]
target = //plugins:go
gotool = //third_party/go:toolchain|go
delvetool = ///third_party/go/github.com_go-delve_delve//cmd/dlv
modfile = //:gomod

[Plugin "python"]
target = //plugins:python
disablevendorflags = true
moduledir = third_party/python

[Plugin "shell"]
target = //plugins:shell

[Plugin "cc"]
target = //plugins:cc

[Sandbox]
build = true
test = true

[Remote]
url =
instance =
numexecutors = 0
